# =========================================================
# CineMatch AI · Professional .gitignore
# =========================================================

# -------------------------------
# Python Cache
# -------------------------------
__pycache__/
*.py[cod]
*$py.class

# -------------------------------
# Virtual Environment
# -------------------------------
venv/
env/
ENV/

# -------------------------------
# Environment Variables
# -------------------------------
.env

# -------------------------------
# VS Code
# -------------------------------
.vscode/

# -------------------------------
# Streamlit
# -------------------------------
.streamlit/

# -------------------------------
# Jupyter Notebook
# -------------------------------
.ipynb_checkpoints/

# -------------------------------
# OS Files
# -------------------------------
.DS_Store
Thumbs.db

# -------------------------------
# Logs
# -------------------------------
*.log

# -------------------------------
# Temporary Files
# -------------------------------
temp/
tmp/

# -------------------------------
# Build / Distribution
# -------------------------------
build/
dist/
*.egg-info/

# -------------------------------
# Machine Learning Model Files
# -------------------------------
model_data/
*.pkl
*.joblib

# -------------------------------
# Cache Files
# -------------------------------
.cache/

# -------------------------------
# Testing
# -------------------------------
.pytest_cache/

# =========================================================
# IMPORTANT
# =========================================================
# DO NOT ignore dataset/
# Deployment needs TMDB CSV files.
# =========================================================